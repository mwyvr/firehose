<!DOCTYPE html>
<html lang="en"{{if .ThemeAttr}} data-theme="{{.ThemeAttr}}"{{end}}>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{.SiteTitle}}{{if .Title}} :: {{.Title}}{{end}}</title>
{{if .LinksNewTab}}<base target="_blank">
{{end -}}
<link rel="stylesheet" href="style.css">
<script>(function(){var d=document.documentElement;d.setAttribute("data-theme-default",d.getAttribute("data-theme")||"");try{var t=localStorage.getItem("firehose:theme");if(t==="light"||t==="dark")d.setAttribute("data-theme",t)}catch(e){}})()</script>
<link rel="icon" href="favicon.svg" type="image/svg+xml">
<link rel="icon" href="favicon.ico" sizes="32x32">
<link rel="apple-touch-icon" href="apple-touch-icon.png">
</head>
<body>
<header class="chrome">
<nav class="nav">
{{- range .Nav}}
<a href="{{.File}}"{{if .Current}} aria-current="page" class="nav__current"{{end}}{{if $.LinksNewTab}} target="_self"{{end}}>{{.Title}}</a>
{{- end}}
<button class="themetoggle" aria-label="Toggle theme">◐</button>
</nav>
<h1 class="page__title">{{.Title}}</h1>
</header>
<main>
{{- range .Items}}
<article class="feeditem" id="i-{{.ID}}">
<h2 class="feeditem__title">{{if .HasLink}}<a href="{{.URL}}">{{.Title}}</a>{{else}}{{.Title}}{{end}}</h2>
<p class="feeditem__meta">
{{- if .Section}}<span class="feeditem__section">{{.Section}}</span> · {{end -}}
<time datetime="{{.Datetime}}">{{.Display}}</time>
{{- if .Source}} · <span class="feeditem__source">{{.Source}}</span>{{end}}
{{- if .AlsoVia}} · <span class="feeditem__alsovia">also via {{.AlsoVia}}</span>{{end}}
{{- if .Author}} · <span class="feeditem__author">{{.Author}}</span>{{end}}
{{- if .ReadMins}} · <span class="feeditem__readtime">~{{.ReadMins}} min</span>{{end}}
{{- if .HasLink}} · <button class="copy" data-copy="{{.URL}}" title="Copy link" aria-label="Copy link">⧉</button> <button class="copy" data-copy="[{{.Title}}]({{.URL}})" title="Copy Markdown link" aria-label="Copy Markdown link">M↓</button>{{end}}
{{- if .NoteURL}} · <a class="note" href="{{.NoteURL}}">note</a>{{end}}
</p>
{{- if .BodyHTML}}
<div class="feeditem__body">{{.BodyHTML}}</div>
{{- end}}
{{- if .Expand}}
<details class="feeditem__more">
<summary>Read more</summary>
<div class="feeditem__full">{{.FullHTML}}</div>
</details>
{{- end}}
</article>
{{- end}}
</main>
<footer class="footer"><a href="https://github.com/mwyvr/firehose">firehose</a> · {{.Version}}</footer>
<script src="river.js" defer></script>
</body>
</html>
